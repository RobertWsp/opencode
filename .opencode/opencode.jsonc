{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode": {
      "options": {},
    },
  },
  "memory": {
    "enabled": true,
    "vaultPath": "~/Obsidian/dev-memory",
    "maxBytes": 6000,
    "maxNotes": 20,
    "autoCapture": true,
    "captureModel": "claude-haiku-4-5-20251001",
    "autoConsolidate": true,
    "consolidateModel": "claude-sonnet-4-5-20250929",
    "injectionStyle": "progressive",
    "smartRetrieval": true,
    "hydeExpansion": false,
    "sessionSummary": true,
    "autoInit": true,
  },
  "mcp": {},
  "tools": {
    "github-triage": false,
    "github-pr-search": false,
  },
}
